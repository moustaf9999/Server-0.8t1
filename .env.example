# Balatro Multiplayer Server - example environment variables
#
# Copy this file to ".env" for local use, or set the variables in your host
# (e.g. Railway -> Variables). NEVER commit a real ".env" or put a real
# ADMIN_DASHBOARD_TOKEN in this repository - ".env" is gitignored.

# ---------------------------------------------------------------------------
# Gameplay TCP server (the socket the Balatro mod connects to)
# ---------------------------------------------------------------------------
# Port the gameplay TCP server binds to internally. If unset:
#   - locally:        defaults to 12345
#   - on Railway:     defaults to RAILWAY_TCP_APPLICATION_PORT or 8788
# GAMEPLAY_PORT=12345

# Network interface to bind. Use 127.0.0.1 for trusted local-only testing.
# On Railway this defaults to 0.0.0.0 so the public proxy can reach it.
# HOST=127.0.0.1

# Generic port some hosts inject. On Railway this is the HTTP port the
# provider routes to. Leave unset locally; the gameplay server ignores PORT
# on Railway (it uses the TCP application port instead).
# PORT=

# ---------------------------------------------------------------------------
# Monitor dashboard (read-only browser UI at /admin)
# Disabled unless BOTH switches below are set. See README "Monitor Dashboard".
# ---------------------------------------------------------------------------
# Master switch: must be 1 / true / yes / on to start the dashboard at all.
MONITOR_DASHBOARD_ENABLED=1

# Login token for the dashboard. REQUIRED. Use a long random secret.
# This is the only thing standing between the public dashboard and your data.
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_DASHBOARD_TOKEN=replace-with-a-long-random-secret

# Port the dashboard HTTP server listens on. Defaults to 8790.
# On Railway, if this is unset the dashboard uses PORT (the provider HTTP port)
# so it is reachable through the Railway HTTP domain.
# Locally, keep this different from GAMEPLAY_PORT to avoid a port clash.
# MONITOR_DASHBOARD_PORT=8790

# Host the dashboard binds to. Defaults to 0.0.0.0.
# MONITOR_DASHBOARD_HOST=0.0.0.0

# ---------------------------------------------------------------------------
# Admin control socket (separate TCP control channel, NOT the dashboard)
# Authenticates commands via RSA signature against admin_public.pem.
# Disabled unless a readable admin_public.pem is present.
# ---------------------------------------------------------------------------
# ADMIN_PORT=8789
# Path to the admin RSA public key. Defaults look for admin_public.pem in the
# project root or .github directory.
# ADMIN_PUBLIC_KEY_PATH=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# MP_LOCAL_SERVER=1            # enable local file logging
# MP_SERVER_LOG_COLOR=1        # stable per-client terminal colors (local)
# MP_VERBOSE_SERVER_LOG=1      # full packet traces (local-only payloads)
# MP_SERVER_LOG_CONSOLE=1      # summarized console trace (container/provider logs)
